{"type":"app","meta":{"headers":{"x-next-cache-tags":"_N_T_/layout,_N_T_/campaigns/layout,_N_T_/campaigns/page,_N_T_/campaigns"}},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/0a2f060a962c327f.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-616e068a201ad621.js\"/><script src=\"/_next/static/chunks/fd9d1056-3eee857bde8f3b06.js\" async=\"\"></script><script src=\"/_next/static/chunks/117-e6f8effb6353785e.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-aa40221319a8983c.js\" async=\"\"></script><script src=\"/_next/static/chunks/972-ceea3baa05359a1c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/campaigns/page-654e14010af09dee.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-9e07af492dbe15bf.js\" async=\"\"></script><title>EIE SA — Enough Is Enough South Africa</title><meta name=\"description\" content=\"Youth-led civil society movement committed to accountability, transparency, and good governance. Enough Is Enough South Africa.\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-screen flex flex-col\"><div class=\"bg-brand-red text-white text-center font-bold uppercase tracking-wide py-2 px-4 text-xs relative\"><span>🔴 UPCOMING: EIE SA × IEC Online Voter Education Workshop — 2026 LGE — Top 8 Political Parties Participating.<!-- --> <a href=\"https://forms.gle/E8VVXN12KRKZhBsV6\" target=\"_blank\" rel=\"noreferrer\" class=\"underline underline-offset-2 hover:text-gray-200 transition-colors\">TARGET: 100+ YOUTH — CLICK HERE TO JOIN →</a></span><button class=\"absolute right-3 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-base font-normal\" aria-label=\"Dismiss\">×</button></div><header class=\"sticky top-0 z-50 bg-brand-charcoal border-b-2 border-brand-red\"><nav class=\"max-w-6xl mx-auto px-6 h-16 flex items-center justify-between\"><a class=\"font-oswald text-xl font-bold tracking-[0.2em] uppercase text-white\" href=\"/\">EIE <span class=\"text-brand-red\">SA</span></a><ul class=\"hidden md:flex items-center gap-1 list-none\"><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/\">Home</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 bg-brand-red text-white\" href=\"/campaigns\">Campaigns</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/join\">Join Us</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/contact\">Contact</a></li></ul><a class=\"hidden md:block btn-red text-xs rounded-sm\" href=\"/join\">Join the Movement</a><button class=\"md:hidden flex flex-col gap-1.5 p-2\" aria-label=\"Toggle menu\"><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span></button></nav></header><main class=\"flex-1\"><div class=\"page-hero\"><div class=\"max-w-6xl mx-auto\"><div class=\"eyebrow\" style=\"color:#ef4444\">Our Work</div><h1 class=\"font-oswald font-bold uppercase text-white leading-none tracking-tight\" style=\"font-size:clamp(2.5rem, 5vw, 4.5rem)\">Active <span class=\"text-brand-red\">Campaigns</span></h1><p class=\"text-gray-400 mt-4 max-w-2xl leading-relaxed\">Focused, evidence-based campaigns that educate citizens, demand accountability, and drive real policy change across South Africa.</p></div></div><section class=\"section-white border-b border-gray-100\"><div class=\"max-w-6xl mx-auto\"><div class=\"border-2 border-brand-red bg-red-50 p-8 relative overflow-hidden\"><div class=\"absolute top-0 left-0 w-full h-1 bg-brand-red\"></div><div class=\"flex items-center gap-2 mb-4\"><span class=\"relative flex h-3 w-3\"><span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-red opacity-75\"></span><span class=\"relative inline-flex rounded-full h-3 w-3 bg-brand-red\"></span></span><span class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-brand-red\">Live Event</span></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 items-start\"><div class=\"md:col-span-2\"><h2 class=\"font-oswald font-bold uppercase text-brand-black leading-tight mb-3\" style=\"font-size:clamp(1.4rem, 2.5vw, 2rem)\">EIE SA × IEC Online Voter Education Workshop</h2><p class=\"text-gray-600 leading-relaxed mb-4\">EIE SA has been invited to a landmark Online Voter Education Workshop with the Independent Electoral Commission (IEC) and the top 8 political parties in South Africa. This is a direct opportunity to learn about the 2026 Local Government Elections, understand your rights as a voter, and engage with party representatives.</p><ul class=\"space-y-2 mb-6 list-none\"><li class=\"flex items-start gap-2 text-sm text-gray-600\"><span class=\"text-brand-red font-bold flex-shrink-0 mt-0.5\">→</span>Live participation with IEC officials and top 8 political parties</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><span class=\"text-brand-red font-bold flex-shrink-0 mt-0.5\">→</span>Q&amp;A on the 2026 LGE — ward elections, voter registration, and your rights</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><span class=\"text-brand-red font-bold flex-shrink-0 mt-0.5\">→</span>Direct civic education from official sources</li><li class=\"flex items-start gap-2 text-sm text-gray-600\"><span class=\"text-brand-red font-bold flex-shrink-0 mt-0.5\">→</span>Open to all South African youth — no registration fee</li></ul><a href=\"https://forms.gle/E8VVXN12KRKZhBsV6\" target=\"_blank\" rel=\"noreferrer\" class=\"btn-red rounded-sm text-sm inline-block\">Register to Attend →</a></div><div class=\"bg-brand-red p-6 text-white\"><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-white/70 mb-4\">Participation</div><div class=\"text-center py-4\"><div class=\"font-oswald font-bold text-white leading-none mb-1\" style=\"font-size:3.5rem\">35</div><div class=\"text-xs text-white/75 uppercase tracking-wide\">Registered</div></div><div class=\"bg-white/20 rounded-full h-2 mb-2\"><div class=\"bg-white rounded-full h-2 transition-all duration-500\" style=\"width:35%\"></div></div><div class=\"text-xs text-white/70 text-center\">Target: 100+ Youth Participants</div><div class=\"border-t border-white/20 mt-4 pt-4 space-y-2\"><div class=\"flex justify-between text-xs\"><span class=\"text-white/60 uppercase tracking-wide\">Format</span><span class=\"text-white font-semibold\">Online / Virtual</span></div><div class=\"flex justify-between text-xs\"><span class=\"text-white/60 uppercase tracking-wide\">Host</span><span class=\"text-white font-semibold\">IEC + EIE SA</span></div><div class=\"flex justify-between text-xs\"><span class=\"text-white/60 uppercase tracking-wide\">Focus</span><span class=\"text-white font-semibold\">2026 LGE</span></div></div></div></div></div></div></section><section class=\"section-off\"><div class=\"max-w-6xl mx-auto\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-0 bg-brand-black overflow-hidden border border-brand-black\"><div class=\"bg-brand-red p-8 flex flex-col justify-between\"><div><div class=\"font-oswald text-xs font-bold tracking-[0.3em] uppercase text-white/70 mb-3\">Active Campaign</div><h2 class=\"font-oswald font-bold uppercase text-white leading-tight mb-4\" style=\"font-size:1.75rem\">Your Vote,<br/>Your Power</h2><div class=\"bg-black/30 px-3 py-2 inline-block mb-4\"><div class=\"font-oswald text-xs font-bold tracking-widest uppercase text-white/60\">Theme</div><div class=\"font-oswald text-sm font-bold text-white\">2026 LGE Accountability</div></div></div><div class=\"mt-6\"><div class=\"font-oswald font-bold text-white leading-none text-3xl\">&quot;2026 IS YOUR RECEIPT.</div><div class=\"font-oswald font-bold text-white/80 leading-none text-3xl\">USE IT.&quot;</div></div></div><div class=\"md:col-span-2 bg-white p-8\"><div class=\"eyebrow\">Interactive Tool</div><h3 class=\"font-oswald text-xl font-bold uppercase text-brand-black mb-1\">Ward Councillor Evaluation Checklist</h3><p class=\"text-sm text-gray-500 mb-6 leading-relaxed\">Use this framework to assess your ward councillor before 2026. Tick each pillar you have verified.</p><div class=\"space-y-3 mb-6\"><div class=\"border p-4 cursor-pointer transition-all duration-150 select-none border-gray-200 hover:border-gray-300 bg-gray-50\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 w-6 h-6 border-2 flex items-center justify-center mt-0.5 transition-all duration-150 border-gray-300\"></div><div><div class=\"flex items-center gap-2 mb-1\"><span class=\"font-oswald text-xs font-bold text-gray-400\">01</span><span class=\"font-oswald text-sm font-bold uppercase text-brand-black\">Attendance</span></div><p class=\"text-xs text-gray-500 leading-relaxed\">Council meeting attendance is public record. A councillor who is constantly absent is not representing you. This is your first check.</p></div></div></div><div class=\"border p-4 cursor-pointer transition-all duration-150 select-none border-gray-200 hover:border-gray-300 bg-gray-50\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 w-6 h-6 border-2 flex items-center justify-center mt-0.5 transition-all duration-150 border-gray-300\"></div><div><div class=\"flex items-center gap-2 mb-1\"><span class=\"font-oswald text-xs font-bold text-gray-400\">02</span><span class=\"font-oswald text-sm font-bold uppercase text-brand-black\">Ward Committee Meetings</span></div><p class=\"text-xs text-gray-500 leading-relaxed\">Your councillor must hold regular ward committee meetings open to residents. If these are not happening — or you have never been notified — that is a failure of duty.</p></div></div></div><div class=\"border p-4 cursor-pointer transition-all duration-150 select-none border-gray-200 hover:border-gray-300 bg-gray-50\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 w-6 h-6 border-2 flex items-center justify-center mt-0.5 transition-all duration-150 border-gray-300\"></div><div><div class=\"flex items-center gap-2 mb-1\"><span class=\"font-oswald text-xs font-bold text-gray-400\">03</span><span class=\"font-oswald text-sm font-bold uppercase text-brand-black\">Service Delivery Reports (IDPs/SDBIPs)</span></div><p class=\"text-xs text-gray-500 leading-relaxed\">Every municipality publishes an Integrated Development Plan and a Service Delivery and Budget Implementation Plan. Your ward&#x27;s targets are in there. Google &quot;[your municipality] SDBIP 2024&quot;.</p></div></div></div><div class=\"border p-4 cursor-pointer transition-all duration-150 select-none border-gray-200 hover:border-gray-300 bg-gray-50\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 w-6 h-6 border-2 flex items-center justify-center mt-0.5 transition-all duration-150 border-gray-300\"></div><div><div class=\"flex items-center gap-2 mb-1\"><span class=\"font-oswald text-xs font-bold text-gray-400\">04</span><span class=\"font-oswald text-sm font-bold uppercase text-brand-black\">Budget Allocation</span></div><p class=\"text-xs text-gray-500 leading-relaxed\">What was allocated to your ward this financial year? Has it been spent? On what? These figures must be publicly available through your municipality.</p></div></div></div><div class=\"border p-4 cursor-pointer transition-all duration-150 select-none border-gray-200 hover:border-gray-300 bg-gray-50\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 w-6 h-6 border-2 flex items-center justify-center mt-0.5 transition-all duration-150 border-gray-300\"></div><div><div class=\"flex items-center gap-2 mb-1\"><span class=\"font-oswald text-xs font-bold text-gray-400\">05</span><span class=\"font-oswald text-sm font-bold uppercase text-brand-black\">Written Accountability</span></div><p class=\"text-xs text-gray-500 leading-relaxed\">Ask your councillor directly — in writing, on social media, or at a public meeting. Their response, or silence, is your answer. Document everything.</p></div></div></div></div><div class=\"bg-gray-100 p-4 mb-4\"><div class=\"flex justify-between items-center mb-2\"><span class=\"font-oswald text-xs font-bold uppercase tracking-wide text-gray-500\">Verification Progress</span><span class=\"font-oswald text-sm font-bold text-brand-red\">0<!-- -->/5 Pillars</span></div><div class=\"bg-gray-200 rounded-full h-1.5\"><div class=\"bg-brand-red rounded-full h-1.5 transition-all duration-300\" style=\"width:0%\"></div></div></div><a href=\"https://www.elections.org.za/pw/voter/Who-Is-My-Ward-Councillor\" target=\"_blank\" rel=\"noreferrer\" class=\"inline-flex items-center gap-2 text-xs font-oswald font-bold uppercase tracking-widest text-brand-red border border-brand-red px-4 py-2 hover:bg-brand-red hover:text-white transition-all duration-150\">IEC Ward Councillor Lookup — elections.org.za →</a></div></div></div></section><section class=\"section-white\"><div class=\"max-w-6xl mx-auto\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-0 overflow-hidden border border-brand-navy\"><div class=\"bg-brand-navy p-8 flex flex-col justify-between\"><div><div class=\"font-oswald text-xs font-bold tracking-[0.3em] uppercase text-white/60 mb-3\">Active Campaign</div><h2 class=\"font-oswald font-bold uppercase text-white leading-tight mb-4\" style=\"font-size:1.75rem\">Our Streets,<br/>Our Rights</h2><div class=\"bg-white/10 px-3 py-2 inline-block mb-4\"><div class=\"font-oswald text-xs font-bold tracking-widest uppercase text-white/60\">Theme</div><div class=\"font-oswald text-sm font-bold text-white\">Immigration Governance</div></div></div><div class=\"mt-6 border-t border-white/20 pt-6\"><p class=\"text-xs text-white/70 leading-relaxed italic\">&quot;This is NOT an anti-foreigner campaign. EIE SA does not promote xenophobia or violence. This is a governance accountability frame demanding the state enforces its own laws.&quot;</p></div></div><div class=\"md:col-span-2 bg-white p-8\"><div class=\"bg-brand-navy/10 border-l-4 border-brand-navy p-4 mb-6\"><p class=\"text-xs text-brand-navy leading-relaxed font-medium\"><strong>EIE SA position:</strong> This campaign is NOT anti-foreigner. EIE SA does not promote xenophobia, ethnic targeting, or violence of any kind. This IS a governance accountability campaign demanding the state enforces its own immigration laws — and adequately resources the communities bearing the burden of that failure.</p></div><div class=\"eyebrow\">The Real Cost in Townships</div><h3 class=\"font-oswald text-xl font-bold uppercase text-brand-black mb-4\">What Non-Enforcement Costs Poor Communities</h3><div class=\"grid grid-cols-1 md:grid-cols-2 gap-3 mb-6\"><div class=\"bg-gray-50 border border-gray-200 p-4\"><div class=\"text-xl mb-2\">🏥</div><div class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-1\">Healthcare</div><p class=\"text-xs text-gray-500 leading-relaxed\">Public clinics in townships are chronically underfunded. When patient load includes those who cannot be traced through the national health system, the system breaks further.</p></div><div class=\"bg-gray-50 border border-gray-200 p-4\"><div class=\"text-xl mb-2\">🏫</div><div class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-1\">Schools</div><p class=\"text-xs text-gray-500 leading-relaxed\">Public schools operate on a per-learner subsidy. Undocumented learners create administrative and resource pressure on schools already at capacity.</p></div><div class=\"bg-gray-50 border border-gray-200 p-4\"><div class=\"text-xl mb-2\">🏘️</div><div class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-1\">Housing</div><p class=\"text-xs text-gray-500 leading-relaxed\">RDP housing waiting lists are for citizens and legal residents. Every irregular jump of that queue means a citizen waits longer.</p></div><div class=\"bg-gray-50 border border-gray-200 p-4\"><div class=\"text-xl mb-2\">💼</div><div class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-1\">Jobs</div><p class=\"text-xs text-gray-500 leading-relaxed\">The informal economy in townships has been significantly displaced. This directly affects the income of the poorest South Africans.</p></div></div><div class=\"bg-brand-navy text-white p-6\"><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-white/60 mb-3\">Know Your Rights &amp; Legal Channels</div><h4 class=\"font-oswald text-lg font-bold uppercase mb-4\">What To Do. What Not To Do.</h4><div class=\"grid grid-cols-1 md:grid-cols-2 gap-4 mb-4\"><div><div class=\"font-oswald text-xs font-bold uppercase tracking-wide text-green-400 mb-2\">✅ DO</div><ul class=\"space-y-2 list-none\"><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-green-400 flex-shrink-0\">→</span>Report to Dept of Home Affairs: 0800 601 190</li><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-green-400 flex-shrink-0\">→</span>Report to SAPS — undocumented presence is a criminal matter</li><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-green-400 flex-shrink-0\">→</span>Document the location and relevant details</li><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-green-400 flex-shrink-0\">→</span>Follow up in writing if your report is ignored</li></ul></div><div><div class=\"font-oswald text-xs font-bold uppercase tracking-wide text-red-400 mb-2\">❌ DO NOT</div><ul class=\"space-y-2 list-none\"><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-red-400 flex-shrink-0\">✕</span>Take the law into your own hands — this is a criminal offence</li><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-red-400 flex-shrink-0\">✕</span>Assault, threaten, or forcibly remove any person</li><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-red-400 flex-shrink-0\">✕</span>Damage property under any circumstances</li><li class=\"text-xs text-white/80 flex gap-2 items-start\"><span class=\"text-red-400 flex-shrink-0\">✕</span>Target people based on appearance or nationality</li></ul></div></div><div class=\"bg-white/10 border border-white/20 p-4 mt-2\"><div class=\"font-oswald text-xs font-bold uppercase tracking-wide text-white/60 mb-1\">Official Reporting Channel</div><div class=\"flex items-center gap-3\"><span class=\"text-2xl\">📞</span><div><div class=\"font-oswald text-lg font-bold text-white\">0800 601 190</div><div class=\"text-xs text-white/60\">Department of Home Affairs — Toll Free</div></div></div></div></div></div></div></div></section><section class=\"section-slate\"><div class=\"max-w-6xl mx-auto\"><div class=\"eyebrow\">Core Mandate</div><h2 class=\"section-title\">Electoral <span class=\"text-brand-red\">Reform</span></h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 mt-8\"><div class=\"bg-white border border-gray-200 p-8\"><div class=\"font-oswald text-4xl font-bold text-brand-red/20 mb-3\">1</div><h3 class=\"font-oswald text-lg font-bold uppercase text-brand-black mb-3\">Direct Election of the President &amp; Premiers</h3><p class=\"text-sm text-gray-500 leading-relaxed mb-4\">Instead of Parliament electing the President, citizens vote directly for presidential candidates. The same applies to each province — voters directly elect their Premiers.</p><div class=\"bg-red-50 border-l-4 border-brand-red p-3 text-xs text-gray-600 leading-relaxed\">Result: A President accountable to 40 million citizens, not a party caucus.</div></div><div class=\"bg-white border border-gray-200 p-8\"><div class=\"font-oswald text-4xl font-bold text-brand-red/20 mb-3\">2</div><h3 class=\"font-oswald text-lg font-bold uppercase text-brand-black mb-3\">The &quot;300 + 100&quot; Mixed Constituency Model</h3><p class=\"text-sm text-gray-500 leading-relaxed mb-4\">300 single-member constituencies — each representing a defined community. 100 proportional seats to preserve political diversity.</p><div class=\"bg-red-50 border-l-4 border-brand-red p-3 text-xs text-gray-600 leading-relaxed\">Result: Every South African has a named MP directly accountable to their community.</div></div></div></div></section><section class=\"section-black\"><div class=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center\"><div><h2 class=\"font-oswald font-bold uppercase text-white leading-tight mb-4\" style=\"font-size:clamp(1.75rem, 3vw, 2.75rem)\">The rules can be <span class=\"text-brand-red\">changed.</span></h2><p class=\"text-gray-400 leading-relaxed\">EIE SA is building the coalition that changes them. Join the movement today.</p></div><div class=\"flex flex-col md:items-end gap-4\"><a class=\"btn-red rounded-sm text-center\" href=\"/join\">Join the Movement →</a><a class=\"btn-outline-dark border-gray-600 text-gray-400 hover:border-white hover:text-white hover:bg-white/5 rounded-sm text-center\" href=\"/contact\">Contact Us</a></div></div></section></main><footer class=\"bg-brand-charcoal text-white\"><div class=\"max-w-6xl mx-auto px-6 py-14 grid grid-cols-1 md:grid-cols-3 gap-10 border-b border-white/10\"><div><div class=\"font-oswald text-xl font-bold tracking-[0.2em] uppercase mb-3\">EIE <span class=\"text-brand-red\">SA</span></div><p class=\"text-sm text-gray-400 leading-relaxed max-w-xs\">Enough Is Enough South Africa is a youth-led civil society movement committed to accountability, transparency, and good governance. We refuse to inherit a broken nation.</p></div><div><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-gray-500 mb-4\">Navigate</div><ul class=\"space-y-2 list-none\"><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/\">Home</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/campaigns\">Campaigns</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/join\">Join Us</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/contact\">Contact</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/join\">Join / Donate</a></li></ul></div><div><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-gray-500 mb-4\">Connect</div><ul class=\"space-y-2 text-sm text-gray-400 list-none\"><li><a href=\"https://x.com/eiesouthafrica?s=21\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">X / Twitter — @eiesouthafrica</a></li><li><a href=\"https://www.facebook.com/share/1EF3WwRFfU/?mibextid=wwXIfr\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">Facebook — EIE SA</a></li><li><a href=\"https://www.instagram.com/eie_sa?igsh=MTFzYWpyZXhqczJhYw==\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">Instagram — @eie_sa</a></li><li><a href=\"https://www.tiktok.com/@enoughisenough_sa\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">TikTok — @enoughisenough_sa</a></li><li><a href=\"#\" class=\"hover:text-brand-red transition-colors\">LinkedIn — EIE SA</a></li><li><a href=\"mailto:enoughisenoughaone@gmail.com\" class=\"hover:text-brand-red transition-colors\">enoughisenoughaone@gmail.com</a></li></ul></div></div><div class=\"max-w-6xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-600\"><span>© 2025 Enough Is Enough South Africa. Non-Profit Civil Society Movement.</span><div class=\"flex gap-4\"><a href=\"#\" class=\"hover:text-brand-red transition-colors\">Privacy Policy</a><a href=\"#\" class=\"hover:text-brand-red transition-colors\">POPIA Compliance</a></div><span class=\"font-oswald font-bold tracking-[0.2em] uppercase text-brand-red\">#EnoughIsEnough</span></div></footer><script src=\"/_next/static/chunks/webpack-616e068a201ad621.js\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0]);self.__next_f.push([2,null])</script><script>self.__next_f.push([1,\"1:HL[\\\"/_next/static/css/0a2f060a962c327f.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"2:I[2846,[],\\\"\\\"]\\n4:I[9107,[],\\\"ClientPageRoot\\\"]\\n5:I[5173,[\\\"972\\\",\\\"static/chunks/972-ceea3baa05359a1c.js\\\",\\\"905\\\",\\\"static/chunks/app/campaigns/page-654e14010af09dee.js\\\"],\\\"default\\\",1]\\n6:I[4707,[],\\\"\\\"]\\n7:I[6423,[],\\\"\\\"]\\n8:I[724,[\\\"972\\\",\\\"static/chunks/972-ceea3baa05359a1c.js\\\",\\\"185\\\",\\\"static/chunks/app/layout-9e07af492dbe15bf.js\\\"],\\\"default\\\",1]\\nb:I[1060,[],\\\"\\\"]\\n9:{}\\nc:[]\\n\"])</script><script>self.__next_f.push([1,\"0:[\\\"$\\\",\\\"$L2\\\",null,{\\\"buildId\\\":\\\"vMy84pf0jvrNabWNKRdse\\\",\\\"assetPrefix\\\":\\\"\\\",\\\"urlParts\\\":[\\\"\\\",\\\"campaigns\\\"],\\\"initialTree\\\":[\\\"\\\",{\\\"children\\\":[\\\"campaigns\\\",{\\\"children\\\":[\\\"__PAGE__