{"type":"app","meta":{"headers":{"x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/0a2f060a962c327f.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-616e068a201ad621.js\"/><script src=\"/_next/static/chunks/fd9d1056-3eee857bde8f3b06.js\" async=\"\"></script><script src=\"/_next/static/chunks/117-e6f8effb6353785e.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-aa40221319a8983c.js\" async=\"\"></script><script src=\"/_next/static/chunks/972-ceea3baa05359a1c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-7ca3d5cf4fbaca4f.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-9e07af492dbe15bf.js\" async=\"\"></script><title>EIE SA — Enough Is Enough South Africa</title><meta name=\"description\" content=\"Youth-led civil society movement committed to accountability, transparency, and good governance. Enough Is Enough South Africa.\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-screen flex flex-col\"><div class=\"bg-brand-red text-white text-center font-bold uppercase tracking-wide py-2 px-4 text-xs relative\"><span>🔴 UPCOMING: EIE SA × IEC Online Voter Education Workshop — 2026 LGE — Top 8 Political Parties Participating.<!-- --> <a href=\"https://forms.gle/E8VVXN12KRKZhBsV6\" target=\"_blank\" rel=\"noreferrer\" class=\"underline underline-offset-2 hover:text-gray-200 transition-colors\">TARGET: 100+ YOUTH — CLICK HERE TO JOIN →</a></span><button class=\"absolute right-3 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-base font-normal\" aria-label=\"Dismiss\">×</button></div><header class=\"sticky top-0 z-50 bg-brand-charcoal border-b-2 border-brand-red\"><nav class=\"max-w-6xl mx-auto px-6 h-16 flex items-center justify-between\"><a class=\"font-oswald text-xl font-bold tracking-[0.2em] uppercase text-white\" href=\"/\">EIE <span class=\"text-brand-red\">SA</span></a><ul class=\"hidden md:flex items-center gap-1 list-none\"><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 bg-brand-red text-white\" href=\"/\">Home</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/campaigns\">Campaigns</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/join\">Join Us</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/contact\">Contact</a></li></ul><a class=\"hidden md:block btn-red text-xs rounded-sm\" href=\"/join\">Join the Movement</a><button class=\"md:hidden flex flex-col gap-1.5 p-2\" aria-label=\"Toggle menu\"><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span></button></nav></header><main class=\"flex-1\"><section class=\"bg-neutral-900 min-h-[560px] flex items-center py-20 px-6\"><div class=\"max-w-6xl mx-auto w-full grid grid-cols-1 md:grid-cols-2 gap-0 items-stretch\"><div class=\"flex flex-col justify-center pr-0 md:pr-16 md:border-r md:border-white/10 py-8\"><div class=\"font-oswald text-xs font-bold tracking-[0.3em] uppercase text-brand-red mb-5 flex items-center gap-3\"><span class=\"block w-7 h-0.5 bg-brand-red\"></span>Youth-Led Civil Society Movement — South Africa</div><h1 class=\"font-oswald font-bold uppercase leading-none tracking-tight text-white mb-4\" style=\"font-size:clamp(3.5rem, 8vw, 7rem);letter-spacing:-0.03em;line-height:0.9\">ENOUGH<br/><span class=\"text-brand-red\">IS</span><br/>ENOUGH.</h1><p class=\"font-oswald text-sm tracking-[0.15em] uppercase text-gray-400 mb-8\">SOUTH AFRICA • YOUTH-LED CIVIL SOCIETY MOVEMENT • EST. 2025</p><p class=\"text-gray-300 text-base leading-relaxed max-w-md mb-8\">South Africa&#x27;s promise of 1994 has not been fulfilled. Democracy gave us the right to vote. It did not give us the power to hold individual leaders accountable. EIE SA exists to reclaim that power.</p><div class=\"flex flex-wrap gap-4\"><a class=\"btn-red rounded-sm\" href=\"/join\">Join the Movement</a><a class=\"btn-outline-dark border-gray-500 text-gray-300 hover:border-white hover:text-white hover:bg-white/10 rounded-sm\" href=\"/campaigns\">Our Campaigns</a></div></div><div class=\"bg-brand-red flex flex-col justify-center pl-0 md:pl-12 py-8 mt-8 md:mt-0 gap-1\"><div class=\"px-10 py-7 bg-black/30\"><div class=\"font-oswald font-bold text-white leading-none mb-2\" style=\"font-size:clamp(2.5rem, 4vw, 3.5rem)\">2026</div><div class=\"text-xs text-white/75 uppercase tracking-wide font-medium leading-tight\">Local Government Elections — Are you registered?</div></div><div class=\"px-10 py-7 bg-black/15\"><div class=\"font-oswald font-bold text-white leading-none mb-2\" style=\"font-size:clamp(2.5rem, 4vw, 3.5rem)\">46%</div><div class=\"text-xs text-white/75 uppercase tracking-wide font-medium leading-tight\">2021 LGE turnout. Half of South Africa stayed home.</div></div><div class=\"px-10 py-7 bg-black/15\"><div class=\"font-oswald font-bold text-white leading-none mb-2\" style=\"font-size:clamp(2.5rem, 4vw, 3.5rem)\">9</div><div class=\"text-xs text-white/75 uppercase tracking-wide font-medium leading-tight\">Provinces. One movement demanding accountability.</div></div></div></div></section><div class=\"bg-brand-red py-3 px-6 border-b border-brand-red-dark overflow-hidden\"><div class=\"max-w-6xl mx-auto flex items-center gap-8 flex-wrap\"><span class=\"font-oswald text-xs font-bold tracking-[0.3em] uppercase text-white/60 flex-shrink-0\">EIE SA</span><span class=\"font-oswald text-sm font-semibold tracking-widest uppercase text-white flex items-center gap-6\">Mobilise<span class=\"text-white/40\">//</span></span><span class=\"font-oswald text-sm font-semibold tracking-widest uppercase text-white flex items-center gap-6\">Educate<span class=\"text-white/40\">//</span></span><span class=\"font-oswald text-sm font-semibold tracking-widest uppercase text-white flex items-center gap-6\">Empower<span class=\"text-white/40\">//</span></span><span class=\"font-oswald text-sm font-semibold tracking-widest uppercase text-white flex items-center gap-6\">Hold Them Accountable<span class=\"text-white/40\">//</span></span><span class=\"font-oswald text-sm font-semibold tracking-widest uppercase text-white flex items-center gap-6\">#EnoughIsEnough</span></div></div><section class=\"section-white\"><div class=\"max-w-6xl mx-auto\"><div class=\"inline-block bg-brand-red text-white font-oswald text-xs font-bold tracking-[0.25em] uppercase px-4 py-2 mb-8\">THE 2026 LOCAL GOVERNMENT ELECTIONS ARE COMING</div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-16 items-start\"><div><div class=\"eyebrow\">Our Position</div><h2 class=\"section-title\">WE REFUSE TO INHERIT A <span class=\"text-brand-red\">BROKEN NATION</span></h2><div class=\"border-l-4 border-brand-red pl-4 mt-6 mb-8\"><p class=\"text-gray-600 leading-relaxed\">South Africa&#x27;s promise of 1994 has not been fulfilled. Corruption and systemic mismanagement have directly contributed to devastating youth unemployment, rising living costs, and social disillusionment. EIE SA exists to change the rules.</p></div><a class=\"btn-red rounded-sm inline-block\" href=\"/join\">JOIN THE MOVEMENT</a></div><div><div class=\"eyebrow\">Our Mission</div><h2 class=\"section-title\">A South Africa Where <span class=\"text-brand-red\">Leaders Answer</span> to Citizens</h2><p class=\"text-gray-600 leading-relaxed mt-4 mb-6\">We believe in building a South Africa where governance serves the people, not political parties. Where accountability is the norm, not the exception. Where young citizens lead the renewal of democracy.</p><p class=\"text-gray-600 leading-relaxed\">Through peaceful activism, civic education, and policy advocacy, EIE SA builds a participatory democracy where citizens are the ultimate guardians of good governance.</p></div></div></div></section><section class=\"section-slate\"><div class=\"max-w-6xl mx-auto\"><div class=\"eyebrow\">What We&#x27;re Doing</div><h2 class=\"section-title\">Focus <span class=\"text-brand-red\">Areas</span></h2><div class=\"grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-200 border border-gray-200 mt-10\"><div class=\"card group bg-white hover:bg-gray-50 transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-3xl mb-4\">🗳️</div><h3 class=\"font-oswald text-lg font-bold uppercase tracking-wide text-brand-black mb-3\">Electoral Reform</h3><p class=\"text-sm text-gray-500 leading-relaxed mb-5\">Direct election of the President and Premiers. A 300+100 mixed constituency Parliament where every MP answers directly to a community — not a party headquarters.</p><a class=\"font-oswald text-xs font-bold tracking-widest uppercase text-brand-red border-b border-transparent group-hover:border-brand-red transition-all duration-150\" href=\"/campaigns\">Learn More →</a></div><div class=\"card group bg-white hover:bg-gray-50 transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-3xl mb-4\">👁️</div><h3 class=\"font-oswald text-lg font-bold uppercase tracking-wide text-brand-black mb-3\">Civic Watchdog Platform</h3><p class=\"text-sm text-gray-500 leading-relaxed mb-5\">A digital reporting hub for citizens to expose corruption and mismanagement. Community Accountability Monitors. A Policy and Governance Desk tracking legislation in real time.</p><a class=\"font-oswald text-xs font-bold tracking-widest uppercase text-brand-red border-b border-transparent group-hover:border-brand-red transition-all duration-150\" href=\"/campaigns\">Learn More →</a></div><div class=\"card group bg-white hover:bg-gray-50 transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-3xl mb-4\">📚</div><h3 class=\"font-oswald text-lg font-bold uppercase tracking-wide text-brand-black mb-3\">Public Education Campaigns</h3><p class=\"text-sm text-gray-500 leading-relaxed mb-5\">Civic literacy for every South African. Your Vote, Your Power. Our Streets, Our Rights. IEC registration drives. Ward councillor accountability tools.</p><a class=\"font-oswald text-xs font-bold tracking-widest uppercase text-brand-red border-b border-transparent group-hover:border-brand-red transition-all duration-150\" href=\"/campaigns\">Learn More →</a></div></div></div></section><section class=\"section-white\"><div class=\"max-w-6xl mx-auto\"><div class=\"eyebrow\">What We Stand For</div><h2 class=\"section-title\">Core <span class=\"text-brand-red\">Values</span></h2><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-gray-100 border border-gray-100 mt-10\"><div class=\"card group bg-gray-50 hover:bg-white transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">⚖️</div><h3 class=\"font-oswald text-base font-bold uppercase tracking-wide text-brand-black mb-2\">Accountability</h3><p class=\"text-sm text-gray-500 leading-relaxed\">Public office is a duty, not a privilege.</p></div><div class=\"card group bg-gray-50 hover:bg-white transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">🔍</div><h3 class=\"font-oswald text-base font-bold uppercase tracking-wide text-brand-black mb-2\">Transparency</h3><p class=\"text-sm text-gray-500 leading-relaxed\">Open government through public scrutiny and participation.</p></div><div class=\"card group bg-gray-50 hover:bg-white transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">✊</div><h3 class=\"font-oswald text-base font-bold uppercase tracking-wide text-brand-black mb-2\">Active Citizenship</h3><p class=\"text-sm text-gray-500 leading-relaxed\">Democracy is not a spectator sport.</p></div><div class=\"card group bg-gray-50 hover:bg-white transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">🏛️</div><h3 class=\"font-oswald text-base font-bold uppercase tracking-wide text-brand-black mb-2\">Integrity</h3><p class=\"text-sm text-gray-500 leading-relaxed\">We hold ourselves to the same standards we demand.</p></div><div class=\"card group bg-gray-50 hover:bg-white transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">🤝</div><h3 class=\"font-oswald text-base font-bold uppercase tracking-wide text-brand-black mb-2\">Solidarity</h3><p class=\"text-sm text-gray-500 leading-relaxed\">Collective action for collective progress.</p></div><div class=\"card group bg-gray-50 hover:bg-white transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">⚡</div><h3 class=\"font-oswald text-base font-bold uppercase tracking-wide text-brand-black mb-2\">Justice &amp; Equality</h3><p class=\"text-sm text-gray-500 leading-relaxed\">Equal access to rights, opportunities, and services.</p></div></div></div></section><section class=\"bg-brand-red py-16 px-6\"><div class=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center\"><div><div class=\"font-oswald text-xs font-bold tracking-[0.3em] uppercase text-white/70 mb-3\">Live Event</div><h2 class=\"font-oswald font-bold uppercase text-white leading-tight mb-4\" style=\"font-size:clamp(1.5rem, 3vw, 2.5rem)\">EIE SA × IEC Online Voter Education Workshop</h2><p class=\"text-white/90 leading-relaxed mb-6\">EIE SA has been invited to a landmark Online Voter Education Workshop with the IEC and the top 8 political parties. This is your opportunity to learn about the 2026 LGE, ask questions directly, and understand your rights as a voter.</p><div class=\"flex flex-wrap gap-4\"><a target=\"_blank\" rel=\"noreferrer\" class=\"bg-white text-brand-red font-oswald font-bold uppercase tracking-widest text-sm px-6 py-3 hover:bg-gray-100 transition-colors duration-150 rounded-sm\" href=\"https://forms.gle/E8VVXN12KRKZhBsV6\">Register Now →</a><a class=\"border-2 border-white text-white font-oswald font-bold uppercase tracking-widest text-sm px-6 py-3 hover:bg-white/10 transition-colors duration-150 rounded-sm\" href=\"/campaigns\">Learn More</a></div></div><div class=\"bg-black/20 p-8 rounded-sm\"><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-white/60 mb-4\">Workshop Details</div><div class=\"space-y-3\"><div class=\"flex gap-4 text-sm border-b border-white/10 pb-3\"><span class=\"font-bold text-white/60 uppercase tracking-wide w-28 flex-shrink-0\">Format</span><span class=\"text-white\">Online — Virtual Room</span></div><div class=\"flex gap-4 text-sm border-b border-white/10 pb-3\"><span class=\"font-bold text-white/60 uppercase tracking-wide w-28 flex-shrink-0\">Participants</span><span class=\"text-white\">IEC + Top 8 Political Parties + EIE SA</span></div><div class=\"flex gap-4 text-sm border-b border-white/10 pb-3\"><span class=\"font-bold text-white/60 uppercase tracking-wide w-28 flex-shrink-0\">Target</span><span class=\"text-white\">100+ Youth Participants</span></div><div class=\"flex gap-4 text-sm border-b border-white/10 pb-3\"><span class=\"font-bold text-white/60 uppercase tracking-wide w-28 flex-shrink-0\">Focus</span><span class=\"text-white\">2026 Local Government Elections</span></div></div></div></div></section><section class=\"section-black\"><div class=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center\"><div><h2 class=\"font-oswald font-bold uppercase text-white leading-tight\" style=\"font-size:clamp(2rem, 4vw, 3.5rem)\">We refuse to inherit a <span class=\"text-brand-red\">broken nation.</span></h2><p class=\"text-gray-400 mt-4 leading-relaxed max-w-lg\">Protest alone won&#x27;t fix a broken system. We must change the rules. Join EIE SA and be part of the movement that does.</p></div><div class=\"flex flex-col gap-4 md:items-end\"><a class=\"btn-red rounded-sm text-center\" href=\"/join\">Join the Movement</a><a class=\"btn-outline-dark border-gray-600 text-gray-400 hover:border-white hover:text-white hover:bg-white/5 rounded-sm text-center\" href=\"/contact\">Contact Us</a></div></div></section></main><footer class=\"bg-brand-charcoal text-white\"><div class=\"max-w-6xl mx-auto px-6 py-14 grid grid-cols-1 md:grid-cols-3 gap-10 border-b border-white/10\"><div><div class=\"font-oswald text-xl font-bold tracking-[0.2em] uppercase mb-3\">EIE <span class=\"text-brand-red\">SA</span></div><p class=\"text-sm text-gray-400 leading-relaxed max-w-xs\">Enough Is Enough South Africa is a youth-led civil society movement committed to accountability, transparency, and good governance. We refuse to inherit a broken nation.</p></div><div><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-gray-500 mb-4\">Navigate</div><ul class=\"space-y-2 list-none\"><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/\">Home</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/campaigns\">Campaigns</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/join\">Join Us</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/contact\">Contact</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/join\">Join / Donate</a></li></ul></div><div><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-gray-500 mb-4\">Connect</div><ul class=\"space-y-2 text-sm text-gray-400 list-none\"><li><a href=\"https://x.com/eiesouthafrica?s=21\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">X / Twitter — @eiesouthafrica</a></li><li><a href=\"https://www.facebook.com/share/1EF3WwRFfU/?mibextid=wwXIfr\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">Facebook — EIE SA</a></li><li><a href=\"https://www.instagram.com/eie_sa?igsh=MTFzYWpyZXhqczJhYw==\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">Instagram — @eie_sa</a></li><li><a href=\"https://www.tiktok.com/@enoughisenough_sa\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">TikTok — @enoughisenough_sa</a></li><li><a href=\"#\" class=\"hover:text-brand-red transition-colors\">LinkedIn — EIE SA</a></li><li><a href=\"mailto:enoughisenoughaone@gmail.com\" class=\"hover:text-brand-red transition-colors\">enoughisenoughaone@gmail.com</a></li></ul></div></div><div class=\"max-w-6xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-600\"><span>© 2025 Enough Is Enough South Africa. Non-Profit Civil Society Movement.</span><div class=\"flex gap-4\"><a href=\"#\" class=\"hover:text-brand-red transition-colors\">Privacy Policy</a><a href=\"#\" class=\"hover:text-brand-red transition-colors\">POPIA Compliance</a></div><span class=\"font-oswald font-bold tracking-[0.2em] uppercase text-brand-red\">#EnoughIsEnough</span><