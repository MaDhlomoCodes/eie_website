{"type":"app","meta":{"headers":{"x-next-cache-tags":"_N_T_/layout,_N_T_/join/layout,_N_T_/join/page,_N_T_/join"}},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/0a2f060a962c327f.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-616e068a201ad621.js\"/><script src=\"/_next/static/chunks/fd9d1056-3eee857bde8f3b06.js\" async=\"\"></script><script src=\"/_next/static/chunks/117-e6f8effb6353785e.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-aa40221319a8983c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/join/page-2d398e4bd9b3fbb9.js\" async=\"\"></script><script src=\"/_next/static/chunks/972-ceea3baa05359a1c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-9e07af492dbe15bf.js\" async=\"\"></script><title>EIE SA — Enough Is Enough South Africa</title><meta name=\"description\" content=\"Youth-led civil society movement committed to accountability, transparency, and good governance. Enough Is Enough South Africa.\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-screen flex flex-col\"><div class=\"bg-brand-red text-white text-center font-bold uppercase tracking-wide py-2 px-4 text-xs relative\"><span>🔴 UPCOMING: EIE SA × IEC Online Voter Education Workshop — 2026 LGE — Top 8 Political Parties Participating.<!-- --> <a href=\"https://forms.gle/E8VVXN12KRKZhBsV6\" target=\"_blank\" rel=\"noreferrer\" class=\"underline underline-offset-2 hover:text-gray-200 transition-colors\">TARGET: 100+ YOUTH — CLICK HERE TO JOIN →</a></span><button class=\"absolute right-3 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-base font-normal\" aria-label=\"Dismiss\">×</button></div><header class=\"sticky top-0 z-50 bg-brand-charcoal border-b-2 border-brand-red\"><nav class=\"max-w-6xl mx-auto px-6 h-16 flex items-center justify-between\"><a class=\"font-oswald text-xl font-bold tracking-[0.2em] uppercase text-white\" href=\"/\">EIE <span class=\"text-brand-red\">SA</span></a><ul class=\"hidden md:flex items-center gap-1 list-none\"><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/\">Home</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/campaigns\">Campaigns</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 bg-brand-red text-white\" href=\"/join\">Join Us</a></li><li><a class=\"font-oswald text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-150 text-gray-400 hover:text-white hover:bg-white/10\" href=\"/contact\">Contact</a></li></ul><a class=\"hidden md:block btn-red text-xs rounded-sm\" href=\"/join\">Join the Movement</a><button class=\"md:hidden flex flex-col gap-1.5 p-2\" aria-label=\"Toggle menu\"><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span><span class=\"block w-5 h-0.5 bg-white transition-all duration-200 \"></span></button></nav></header><main class=\"flex-1\"><div class=\"page-hero\"><div class=\"max-w-6xl mx-auto\"><div class=\"eyebrow\" style=\"color:#ef4444\">Get Involved</div><h1 class=\"font-oswald font-bold uppercase text-white leading-none tracking-tight\" style=\"font-size:clamp(2.5rem, 5vw, 4.5rem)\">Join the <span class=\"text-brand-red\">Movement</span></h1><p class=\"text-gray-400 mt-4 max-w-2xl leading-relaxed\">EIE SA is not just a protest movement — it is a nation-building project. Protest alone won&#x27;t fix a broken system. We must change the rules together.</p></div></div><section class=\"section-slate\"><div class=\"max-w-6xl mx-auto\"><div class=\"eyebrow\">What You&#x27;ll Be Part Of</div><h2 class=\"section-title\">The <span class=\"text-brand-red\">Work</span></h2><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-gray-200 border border-gray-200 mt-8\"><div class=\"card group bg-white hover:bg-gray-50 transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">🗳️</div><h3 class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-2\">Electoral Reform Advocacy</h3><p class=\"text-xs text-gray-400 leading-relaxed\">Push for direct elections and a 300+100 Parliament model.</p></div><div class=\"card group bg-white hover:bg-gray-50 transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">📚</div><h3 class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-2\">Civic Education</h3><p class=\"text-xs text-gray-400 leading-relaxed\">Voter education campaigns, ward councillor accountability tools, IEC registration drives.</p></div><div class=\"card group bg-white hover:bg-gray-50 transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">👁️</div><h3 class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-2\">Governance Watchdog</h3><p class=\"text-xs text-gray-400 leading-relaxed\">Track corruption, service delivery failures, and government accountability.</p></div><div class=\"card group bg-white hover:bg-gray-50 transition-colors duration-200\"><div class=\"card-top-bar\"></div><div class=\"text-2xl mb-3\">📢</div><h3 class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-2\">Media &amp; Communications</h3><p class=\"text-xs text-gray-400 leading-relaxed\">Build our digital presence across X, Instagram, Facebook, TikTok, and LinkedIn.</p></div></div></div></section><section class=\"section-white\"><div class=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-16\"><div class=\"md:col-span-1\"><div class=\"eyebrow\">Application</div><h2 class=\"section-title\">Volunteer <span class=\"text-brand-red\">Application</span></h2><p class=\"text-gray-500 text-sm leading-relaxed mb-8\">Fill in your details below. The EIE SA team will be in touch with how you can get involved in your province.</p><div class=\"space-y-4\"><div class=\"flex gap-4 items-start\"><span class=\"text-xl flex-shrink-0 mt-0.5\">📍</span><div><div class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-0.5\">9 Provinces</div><div class=\"text-xs text-gray-400 leading-relaxed\">We are building chapters across all nine provinces.</div></div></div><div class=\"flex gap-4 items-start\"><span class=\"text-xl flex-shrink-0 mt-0.5\">🔒</span><div><div class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-0.5\">POPIA Compliant</div><div class=\"text-xs text-gray-400 leading-relaxed\">Your data is processed in strict accordance with South African privacy law.</div></div></div><div class=\"flex gap-4 items-start\"><span class=\"text-xl flex-shrink-0 mt-0.5\">🤝</span><div><div class=\"font-oswald text-sm font-bold uppercase text-brand-black mb-0.5\">Community First</div><div class=\"text-xs text-gray-400 leading-relaxed\">Every role serves the movement and the communities we represent.</div></div></div></div><div class=\"mt-8 bg-gray-50 border border-gray-200 p-4\"><div class=\"font-oswald text-xs font-bold uppercase tracking-widest text-gray-400 mb-2\">Direct Contact</div><a href=\"mailto:enoughisenoughaone@gmail.com\" class=\"text-sm text-brand-red hover:underline break-all\">enoughisenoughaone@gmail.com</a></div></div><div class=\"md:col-span-2\"><form noValidate=\"\"><div class=\"mb-5\"><label for=\"fullName\" class=\"block font-oswald text-xs font-bold uppercase tracking-widest text-gray-500 mb-2\">Full Name <span class=\"text-brand-red\">*</span></label><input id=\"fullName\" type=\"text\" placeholder=\"Thabo Nkosi\" class=\"w-full bg-white border text-brand-black font-inter text-sm px-4 py-3 outline-none transition-colors duration-150 border-gray-200 focus:border-brand-red\" value=\"\"/></div><div class=\"mb-5\"><label for=\"email\" class=\"block font-oswald text-xs font-bold uppercase tracking-widest text-gray-500 mb-2\">Email Address <span class=\"text-brand-red\">*</span></label><input id=\"email\" type=\"email\" placeholder=\"you@example.com\" class=\"w-full bg-white border text-brand-black font-inter text-sm px-4 py-3 outline-none transition-colors duration-150 border-gray-200 focus:border-brand-red\" value=\"\"/></div><div class=\"mb-5\"><label for=\"phone\" class=\"block font-oswald text-xs font-bold uppercase tracking-widest text-gray-500 mb-2\">WhatsApp / Phone Number <span class=\"text-brand-red\">*</span></label><input id=\"phone\" type=\"tel\" placeholder=\"+27 XX XXX XXXX\" class=\"w-full bg-white border text-brand-black font-inter text-sm px-4 py-3 outline-none transition-colors duration-150 border-gray-200 focus:border-brand-red\" value=\"\"/></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-5 mb-5\"><div><label for=\"province\" class=\"block font-oswald text-xs font-bold uppercase tracking-widest text-gray-500 mb-2\">Province / City <span class=\"text-brand-red\">*</span></label><select id=\"province\" class=\"w-full bg-white border text-brand-black font-inter text-sm px-4 py-3 outline-none transition-colors duration-150 appearance-none border-gray-200 focus:border-brand-red\"><option value=\"\" selected=\"\">Select province...</option><option value=\"Gauteng\">Gauteng</option><option value=\"Western Cape\">Western Cape</option><option value=\"KwaZulu-Natal\">KwaZulu-Natal</option><option value=\"Eastern Cape\">Eastern Cape</option><option value=\"Limpopo\">Limpopo</option><option value=\"Mpumalanga\">Mpumalanga</option><option value=\"North West\">North West</option><option value=\"Free State\">Free State</option><option value=\"Northern Cape\">Northern Cape</option></select></div><div><label for=\"role\" class=\"block font-oswald text-xs font-bold uppercase tracking-widest text-gray-500 mb-2\">Your Path <span class=\"text-brand-red\">*</span></label><select id=\"role\" class=\"w-full bg-white border text-brand-black font-inter text-sm px-4 py-3 outline-none transition-colors duration-150 appearance-none border-gray-200 focus:border-brand-red\"><option value=\"\" disabled=\"\" selected=\"\">Select your path...</option><option value=\"general\">General Member</option><option value=\"media\">Media &amp; Communications Team</option><option value=\"volunteer\">Volunteer Hub</option><option value=\"partner\">Strategic Collaboration / Partner</option></select></div></div><div class=\"mb-6 p-4 border border-gray-200 bg-gray-50\"><label class=\"flex items-start gap-3 cursor-pointer\"><div class=\"relative flex-shrink-0 mt-0.5\"><input type=\"checkbox\" class=\"sr-only\"/><div class=\"w-5 h-5 border-2 flex items-center justify-center transition-all duration-150 bg-white border-gray-300\"></div></div><span class=\"text-xs text-gray-500 leading-relaxed\"><strong class=\"text-brand-black\">POPIA Consent (Required):</strong> <!-- -->I consent to EIE SA processing my personal information in strict accordance with the Protection of Personal Information Act (POPIA). My data will be used solely for movement communication and coordination purposes.</span></label></div><button type=\"submit\" class=\"w-full font-oswald font-bold uppercase tracking-widest text-sm text-white py-4 transition-all duration-150 bg-brand-red hover:bg-brand-red-dark\">Submit Application</button></form></div></div></section></main><footer class=\"bg-brand-charcoal text-white\"><div class=\"max-w-6xl mx-auto px-6 py-14 grid grid-cols-1 md:grid-cols-3 gap-10 border-b border-white/10\"><div><div class=\"font-oswald text-xl font-bold tracking-[0.2em] uppercase mb-3\">EIE <span class=\"text-brand-red\">SA</span></div><p class=\"text-sm text-gray-400 leading-relaxed max-w-xs\">Enough Is Enough South Africa is a youth-led civil society movement committed to accountability, transparency, and good governance. We refuse to inherit a broken nation.</p></div><div><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-gray-500 mb-4\">Navigate</div><ul class=\"space-y-2 list-none\"><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/\">Home</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/campaigns\">Campaigns</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/join\">Join Us</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/contact\">Contact</a></li><li><a class=\"text-sm text-gray-400 hover:text-brand-red transition-colors duration-150\" href=\"/join\">Join / Donate</a></li></ul></div><div><div class=\"font-oswald text-xs font-bold tracking-[0.25em] uppercase text-gray-500 mb-4\">Connect</div><ul class=\"space-y-2 text-sm text-gray-400 list-none\"><li><a href=\"https://x.com/eiesouthafrica?s=21\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">X / Twitter — @eiesouthafrica</a></li><li><a href=\"https://www.facebook.com/share/1EF3WwRFfU/?mibextid=wwXIfr\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">Facebook — EIE SA</a></li><li><a href=\"https://www.instagram.com/eie_sa?igsh=MTFzYWpyZXhqczJhYw==\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">Instagram — @eie_sa</a></li><li><a href=\"https://www.tiktok.com/@enoughisenough_sa\" target=\"_blank\" rel=\"noreferrer\" class=\"hover:text-brand-red transition-colors\">TikTok — @enoughisenough_sa</a></li><li><a href=\"#\" class=\"hover:text-brand-red transition-colors\">LinkedIn — EIE SA</a></li><li><a href=\"mailto:enoughisenoughaone@gmail.com\" class=\"hover:text-brand-red transition-colors\">enoughisenoughaone@gmail.com</a></li></ul></div></div><div class=\"max-w-6xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-gray-600\"><span>© 2025 Enough Is Enough South Africa. Non-Profit Civil Society Movement.</span><div class=\"flex gap-4\"><a href=\"#\" class=\"hover:text-brand-red transition-colors\">Privacy Policy</a><a href=\"#\" class=\"hover:text-brand-red transition-colors\">POPIA Compliance</a></div><span class=\"font-oswald font-bold tracking-[0.2em] uppercase text-brand-red\">#EnoughIsEnough</span></div></footer><script src=\"/_next/static/chunks/webpack-616e068a201ad621.js\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0]);self.__next_f.push([2,null])</script><script>self.__next_f.push([1,\"1:HL[\\\"/_next/static/css/0a2f060a962c327f.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"2:I[2846,[],\\\"\\\"]\\n4:I[9107,[],\\\"ClientPageRoot\\\"]\\n5:I[8797,[\\\"532\\\",\\\"static/chunks/app/join/page-2d398e4bd9b3fbb9.js\\\"],\\\"default\\\",1]\\n6:I[4707,[],\\\"\\\"]\\n7:I[6423,[],\\\"\\\"]\\n8:I[724,[\\\"972\\\",\\\"static/chunks/972-ceea3baa05359a1c.js\\\",\\\"185\\\",\\\"static/chunks/app/layout-9e07af492dbe15bf.js\\\"],\\\"default\\\",1]\\nb:I[1060,[],\\\"\\\"]\\n9:{}\\nc:[]\\n\"])</script><script>self.__next_f.push([1,\"0:[\\\"$\\\",\\\"$L2\\\",null,{\\\"buildId\\\":\\\"vMy84pf0jvrNabWNKRdse\\\",\\\"assetPrefix\\\":\\\"\\\",\\\"urlParts\\\":[\\\"\\\",\\\"join\\\"],\\\"initialTree\\\":[\\\"\\\",{\\\"children\\\":[\\\"join\\\",{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]},\\\"$undefine